# Copy this file to `.env` in the project root before running `docker compose up`.
# Use the same values on both laptops if you want both machines to see the same data.

# Shared MongoDB for both laptops. Examples:
# Local Docker Mongo on the same machine:
# MONGODB_URI=mongodb://mongo:27017
#
# MongoDB Atlas / central server:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net
MONGODB_URI=mongodb://mongo:27017

# Database name inside MongoDB.
MONGODB_DB=agri_market_intel

# Backend -> model service URL.
MODEL_SERVICE_URL=http://model_service:8001

# Maximum mandis returned by district/state market queries.
MAX_MARKETS_PER_SCOPE=100
